{
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "target": "ESNext",
    "jsx": "react-jsx",
    "lib": ["ESNext", "DOM"],
    "baseUrl": ".",
    "paths": {
      "@renderer/*": ["src/*"]
    }
  },
  "include": ["src/**/*", "tests/**/*"]
}
